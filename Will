<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Image Popup</title>

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background: rgba(0, 0, 0, 0.9);
            width: 100vw;
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            overflow: hidden;
        }

        img {
            max-width: 95%;
            max-height: 95%;
            border-radius: 10px;
        }
    </style>
</head>
<body>

    <!-- Replace the image link below with your own image URL -->
    <img src="https://i.imgur.com/example.jpg" alt="Image">

</body>
</html>
